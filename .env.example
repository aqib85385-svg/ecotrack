# Port configuration for the Express server
PORT=5000

# Environment execution mode (development, production, test)
NODE_ENV=development

# Gemini API configuration for the AI Coach
# Set to a valid API Key to enable generative recommendations, or leave unset to use fallback
GEMINI_API_KEY=PLACEHOLDER

# System Configuration & Feature Flags
ENABLE_AI=true
ENABLE_BENCHMARKING=true
ENABLE_SCENARIO_PLANNER=true
ENABLE_GAMIFICATION=true
ENABLE_CARBON_TWIN=true
